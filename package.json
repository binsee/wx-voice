{
  "name": "wx-voice",
  "version": "0.2.1",
  "description": "Convert audio files between Tencent apps (Weixin / Wechat, QQ) and Silk codec with other general format such as MP3 and M4A",
  "keywords": [
    "wechat",
    "weixin",
    "mini",
    "program",
    "silk",
    "slk",
    "convert",
    "converter",
    "decode",
    "decoder",
    "encode",
    "encoder"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/Ang-YC/wx-voice",
  "license": "MIT",
  "author": "AngYC <me@angyc.com> (https://angyc.com/)",
  "bin": {
    "wx-voice": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "test": "jest --runInBand"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ang-YC/wx-voice.git"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "1.1.0",
    "@ffprobe-installer/ffprobe": "2.1.2",
    "cli-spinner": "^0.2.6",
    "command-line-args": "^4.0.7",
    "randomatic": "^1.1.7",
    "read-chunk": "^2.1.0",
    "strong-data-uri": "^1.0.4"
  },
  "devDependencies": {
    "@types/command-line-args": "^5.2.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/randomatic": "^3.1.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  }
}
